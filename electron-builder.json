{
    "appId": "com.artemis.insights",
    "productName": "Artemis",
    "copyright": "Copyright © 2025 Mateus Fagundes",
    "forceCodeSigning": false,
    "files": ["dist-electron", "dist-react"],
    "directories": {
        "output": "dist",
        "buildResources": "build"
    },
    "asar": true,
    "asarUnpack": ["**/*.node", "**/*.dll"],
    "icon": "build/icons/png/256x256.png",
    "mac": {
        "target": [
            {
                "target": "dmg",
                "arch": ["x64", "arm64"]
            }
        ],
        "icon": "build/icons/mac/icon.icns",
        "category": "public.app-category.business",
        "artifactName": "Artemis-${version}-${arch}.dmg"
    },
    "linux": {
        "target": [
            {
                "target": "deb",
                "arch": ["x64"]
            },
            {
                "target": "rpm",
                "arch": ["x64"]
            },
            {
                "target": "AppImage",
                "arch": ["x64"]
            }
        ],
        "category": "Office",
        "icon": "build/icons/png",
        "artifactName": "Artemis-${version}-${arch}.${ext}"
    },
    "win": {
        "target": [
            {
                "target": "nsis",
                "arch": ["x64"]
            }
        ],
        "icon": "build/icons/win/icon.ico",
        "sign": false
    },
    "nsis": {
        "oneClick": false,
        "allowToChangeInstallationDirectory": true,
        "installerIcon": "build/icons/win/icon.ico",
        "uninstallerIcon": "build/icons/win/icon.ico",
        "installerHeaderIcon": "build/icons/win/icon.ico",
        "createDesktopShortcut": true,
        "createStartMenuShortcut": true,
        "shortcutName": "Artemis",
        "artifactName": "Artemis-setup.exe"
    },
    "portable": {
        "artifactName": "Artemis-portable.exe"
    }
}